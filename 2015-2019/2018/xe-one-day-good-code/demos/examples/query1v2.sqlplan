<ShowPlanXML xmlns="http://schemas.microsoft.com/sqlserver/2004/07/showplan" Version="1.1" Build="10.50.6000.34">
  <BatchSequence>
    <Batch>
      <Statements>
        <StmtSimple StatementText="DECLARE @dataa datetime, @datada datetime, @cdistgest varchar(10), @cdistpropr varchar(5)&#xD;&#xA;SET @cdistpropr = '00002'&#xD;&#xA;SET @datada = Convert(Datetime,'28/12/2016',103)&#xD;&#xA;SET @dataa = Convert(Datetime,'29/12/2016',103)&#xD;&#xA;SET @cdistgest = '00002'&#xD;&#xA;--- RIGHE 90 E 97 ---&#xD;&#xA;SELECT DISTINCT CASE WHEN DET.PRGRGFCEXT = 90 THEN -1 ELSE DET.PRGRGFCEXT END as Ordina,&#xD;&#xA;&#x9;ISNULL(TES.IMRIMFC,0) as IMRIMFC, TES.CDTPFC as TipoFoglio, 'FE' as Costante, TES.CDISTCOLL as Codage,&#xD;&#xA;&#x9;DET.nufc as NuFcExample, DET.NUFCEXT as NumfcExt, TES.DTFC as Datafc,  ISNULL(DET.PRGRGFCEXT,0) as Rigafc,&#xD;&#xA;&#x9;DET.IDMOV as Nucon, DET.CDCAUSMOV as Tipop, ISNULL(TES.FLQUADRIM,'N') as FLQUADRIM, &#xD;&#xA;&#x9;CASE WHEN DET.CDCAUSMOV IN ('SQ','RP','IS','RS') THEN (-1*DET.IMAVERE) ELSE &#xD;&#xA;        CASE WHEN DET.CDCAUSMOV IN ('DG') THEN 0 ELSE &#xD;&#xA;        CASE WHEN DET.CDCAUSMOV IN ('DP') THEN (DET.IMDARE +(-1*DET.IMAVERE)) ELSE  DET.IMDARE END END END as Impdare,&#xD;&#xA;&#x9;CASE WHEN DET.CDCAUSMOV IN ('SQ','RP','IS','RS') THEN (-1*DET.IMDARE) ELSE &#xD;&#xA;        CASE WHEN DET.CDCAUSMOV IN ('DP') THEN 0 ELSE &#xD;&#xA;        CASE WHEN DET.CDCAUSMOV IN ('DG') THEN (DET.IMAVERE +(-1*DET.IMDARE)) ELSE  DET.IMAVERE END END END as Impavere,&#xD;&#xA;&#x9;CASE WHEN NOT EXISTS(&#xD;&#xA;&#x9;&#x9;SELECT 1 FROM SVGES020 A (NOLOCK) WHERE A.CDISTPROPR = DET.CDISTPROPR AND A.NUFC = DET.NUFC AND A.PRGRGFC &gt; DET.PRGRGFC AND A.CDISTGEST = DET.CDISTGEST)&#xD;&#xA;&#x9;&#x9;THEN 'U'&#xD;&#xA;&#x9;&#x9;ELSE CASE WHEN NOT EXISTS(&#xD;&#xA;&#x9;&#x9;&#x9;SELECT 1 FROM SVGES020 A (NOLOCK) WHERE A.CDISTPROPR = DET.CDISTPROPR AND A.NUFC = DET.NUFC AND A.PRGRGFC &lt; DET.PRGRGFC AND A.CDISTGEST = DET.CDISTGEST)&#xD;&#xA;&#x9;&#x9;THEN 'P' ELSE '' END END as tipoDett, '' as Produt,&#xD;&#xA;&#x9;'' as Ramo, '' as Nupol, '' as Agsin, '' as Esersin, '' as Nusin, '' as Nome, TES.DTFC as Datainc, TES.DTFC as Dataeff,&#xD;&#xA;&#x9;'' as Mezzopag, '' as CodProd,  ' ' as Tipoincasso, 'X' as Tappo, 'RN' as TipoRiga, TES.DTCONTFC, '' as CDTPPNA, NULL AS PRGMOV, DET.TRANSID &#xD;&#xA;FROM SVGES011 TES (NOLOCK)&#xD;&#xA;INNER JOIN SVGES020 DET (NOLOCK) ON TES.CDISTPROPR = DET.CDISTPROPR AND TES.CDISTGEST = DET.CDISTGEST AND DET.PRGRGFCEXT IN (90,97)&#xD;&#xA;&#x9;AND TES.CDTPFC = DET.CDTPFC AND TES.CDISTCOLL = DET.CDISTCOLL AND TES.NUFC = DET.NUFC AND TES.CDSTFC = 'C'&#xD;&#xA;WHERE TES.CDISTPROPR = @cdistpropr AND TES.DTCONTFC BETWEEN @datada AND @dataa AND TES.CDISTGEST = @cdistgest&#xD;&#xA;        AND DET.PRGRGFCEXT IS NOT NULL&#xD;&#xA;UNION ALL&#xD;&#xA;--- CASO PNA ---&#xD;&#xA;SELECT DISTINCT CASE WHEN DET.PRGRGFCEXT = 90 THEN -1 ELSE DET.PRGRGFCEXT END as Ordina,&#xD;&#xA;&#x9;ISNULL(TES.IMRIMFC,0) as IMRIMFC, TES.CDTPFC as TipoFoglio, 'FE' as Costante, TES.CDISTCOLL as Codage,&#xD;&#xA;&#x9;DET.nufc as NuFcExample, DET.NUFCEXT as NumfcExt, TES.DTFC as Datafc,  ISNULL(DET.PRGRGFCEXT,0) as Rigafc,&#xD;&#xA;&#x9;DET.IDMOV as Nucon, DET.CDCAUSMOV as Tipop, ISNULL(TES.FLQUADRIM,'N') as FLQUADRIM,&#xD;&#xA;&#x9;CASE WHEN DET.CDCAUSMOV IN ('SQ','RP','IS','RS') THEN (-1*DET.IMAVERE) ELSE &#xD;&#xA;        CASE WHEN DET.CDCAUSMOV IN ('DG') THEN 0 ELSE &#xD;&#xA;        CASE WHEN DET.CDCAUSMOV IN ('DP') THEN (DET.IMDARE +(-1*DET.IMAVERE)) ELSE  DET.IMDARE END END END as Impdare,&#xD;&#xA;&#x9;CASE WHEN DET.CDCAUSMOV IN ('SQ','RP','IS','RS') THEN (-1*DET.IMDARE) ELSE &#xD;&#xA;        CASE WHEN DET.CDCAUSMOV IN ('DP') THEN 0 ELSE &#xD;&#xA;        CASE WHEN DET.CDCAUSMOV IN ('DG') THEN (DET.IMAVERE +(-1*DET.IMDARE)) ELSE  DET.IMAVERE END END END as Impavere,&#xD;&#xA;&#x9;CASE WHEN NOT EXISTS(&#xD;&#xA;&#x9;&#x9;SELECT 1 FROM SVGES020 A (NOLOCK) WHERE A.CDISTPROPR = DET.CDISTPROPR AND A.NUFC = DET.NUFC AND A.PRGRGFC &gt; DET.PRGRGFC AND A.CDISTGEST = DET.CDISTGEST)&#xD;&#xA;&#x9;&#x9;THEN 'U'&#xD;&#xA;&#x9;&#x9;ELSE CASE WHEN NOT EXISTS(&#xD;&#xA;&#x9;&#x9;&#x9;SELECT 1 FROM SVGES020 A (NOLOCK) WHERE A.CDISTPROPR = DET.CDISTPROPR AND A.NUFC = DET.NUFC AND A.PRGRGFC &lt; DET.PRGRGFC AND A.CDISTGEST = PNA.CDISTGEST)&#xD;&#xA;&#x9;&#x9;THEN 'P' ELSE '' END END as tipoDett, PNA.CDUTENTE as Produt,&#xD;&#xA;&#x9;'' as Ramo, ISNULL(PNA.NUPOLIZ,'') as Nupol, '' as Agsin, '' as Esersin, '' as Nusin,&#xD;&#xA;&#x9;UPPER(COALESCE(LTRIM(ISNULL(NULLIF(SOG.DSCOGNOME,''),'') + ' ' + SOG.DSNOME),PNA.DSPNA,'')) as Nome,&#xD;&#xA;&#x9;COALESCE(PNA.DTCONTPNA,PNA.DTEFFPNA,TES.DTFC) as Datainc,&#xD;&#xA;&#x9;COALESCE(PNA.DTEFFPNA,PNA.DTCONTPNA,TES.DTFC) as Dataeff,&#xD;&#xA;&#x9;CASE ISNULL(PNA.CDMOPAG," StatementId="1" StatementCompId="5" StatementType="SELECT" StatementSubTreeCost="19475.3" StatementEstRows="1.73682e+007" StatementOptmLevel="FULL" QueryHash="0xAD451F355673D218" QueryPlanHash="0x22BA29BC559863F7">
